<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- SEO Dynamique -->
    <title>
        <%= seoTitle || title || 'GeoImpact Tech - Consultance en Environnement, Développement et Géomatique' %>
    </title>
    <meta name="description"
        content="<%= metaDescription || 'GeoImpact Tech - Cabinet de consultance spécialisé en environnement, développement durable et géomatique. Formations professionnelles et études d\'impact.' %>">
    <% if (typeof canonicalUrl !=='undefined' && canonicalUrl) { %>
        <link rel="canonical" href="<%= canonicalUrl %>">
        <% } %>

            <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
            <link
                href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&family=Raleway:wght@300;400;500;600;700&display=swap"
                rel="stylesheet">
            <link rel="stylesheet" href="/css/style.css">

            <link rel="icon" type="image/png"
                href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%230a5c36'/%3E%3Ctext x='50' y='70' font-size='60' text-anchor='middle' fill='white' font-family='Arial'%3EG%3C/text%3E%3C/svg%3E">

            <style>
                /* Styles spécifiques pour l'organisation du header */
                .header-container {
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    gap: 15px;
                }

                .logo {
                    flex-shrink: 0;
                }

                .logo h1 {
                    font-size: 24px;
                    white-space: nowrap;
                }

                .header-actions {
                    display: flex;
                    align-items: center;
                    gap: 5px;
                    flex-shrink: 0;
                }

                .search-toggle-btn {
                    background: none;
                    border: none;
                    font-size: 18px;
                    cursor: pointer;
                    color: var(--primary);
                    padding: 8px 10px;
                    border-radius: 50%;
                    transition: all 0.3s ease;
                    width: 40px;
                    height: 40px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }

                .client-link {
                    display: flex;
                    align-items: center;
                    gap: 8px;
                    color: var(--primary);
                    text-decoration: none;
                    font-size: 14px;
                    padding: 8px 12px;
                    border-radius: 25px;
                    transition: all 0.3s ease;
                }

                .client-link i {
                    font-size: 16px;
                }

                .mobile-menu-btn {
                    background: none;
                    border: none;
                    font-size: 22px;
                    cursor: pointer;
                    color: var(--primary);
                    padding: 8px;
                    border-radius: 50%;
                    width: 40px;
                    height: 40px;
                    display: none;
                    align-items: center;
                    justify-content: center;
                }

                .language-selector {
                    display: flex;
                    align-items: center;
                    gap: 5px;
                    margin-left: 5px;
                }

                .lang-flag {
                    color: var(--primary);
                    text-decoration: none;
                    font-size: 14px;
                    padding: 5px 8px;
                    border-radius: 20px;
                }

                body.dark-mode .lang-flag {
                    color: var(--accent);
                }

                @media (min-width: 993px) {
                    nav ul {
                        display: flex;
                        list-style: none;
                    }

                    nav ul li {
                        margin-left: 30px;
                    }

                    .mobile-menu-btn {
                        display: none !important;
                    }
                }

                @media (max-width: 992px) {
                    nav ul {
                        display: none;
                    }

                    .mobile-menu-btn {
                        display: flex !important;
                    }
                }

                @media (max-width: 768px) {
                    .logo h1 {
                        font-size: 18px;
                    }

                    .client-link span {
                        display: none;
                    }

                    .client-link {
                        padding: 8px;
                        width: 40px;
                        justify-content: center;
                    }

                    .client-link i {
                        font-size: 18px;
                        margin: 0;
                    }

                    .language-selector {
                        display: none;
                    }
                }

                @media (max-width: 480px) {
                    .logo h1 {
                        font-size: 15px;
                    }

                    .header-actions {
                        gap: 2px;
                    }
                }
            </style>
</head>

<body>
    <!-- Header & Navigation -->
    <header>
        <div class="container header-container">
            <div class="mobile-menu-btn">
                <i class="fas fa-bars"></i>
            </div>

            <div class="logo">
                <a href="/">
                    <h1>Geo<span>Impact</span> Tech</h1>
                </a>
            </div>

            <nav>
                <ul>
                    <li><a href="/" class="<%= currentPage === 'home' ? 'active' : '' %>">Accueil</a></li>
                    <li><a href="/formations" class="<%= currentPage === 'formations' ? 'active' : '' %>">Formations</a>
                    </li>
                    <li><a href="/blog" class="<%= currentPage === 'blog' ? 'active' : '' %>">Blog</a></li>
                    <li><a href="/contact" class="<%= currentPage === 'contact' ? 'active' : '' %>">Contact</a></li>
                </ul>
            </nav>

            <div class="header-actions">
                <button id="searchToggleBtn" class="search-toggle-btn" data-tooltip="Rechercher">
                    <i class="fas fa-search"></i>
                </button>

                <a href="/client/login" class="client-link">
                    <i class="fas fa-user-circle"></i>
                    <span>Espace client</span>
                </a>

                <div class="language-selector">
                    <a href="?lang=fr" class="lang-flag">🇫🇷 FR</a>
                    <a href="?lang=en" class="lang-flag">🇬🇧 EN</a>
                </div>
            </div>
        </div>
    </header>

    <!-- Menu Mobile Overlay -->
    <div class="mobile-menu-overlay">
        <button class="close-menu">
            <i class="fas fa-times"></i>
        </button>
        <div class="mobile-menu-container">
            <ul>
                <li><a href="/">Accueil</a></li>
                <li><a href="/formations">Formations</a></li>
                <li><a href="/blog">Blog</a></li>
                <li><a href="/contact">Contact</a></li>
                <li><a href="/client/login"><i class="fas fa-user-circle"></i> Mon compte</a></li>
            </ul>
        </div>
    </div>

    <!-- Modal de recherche -->
    <div id="searchModal" class="search-modal" style="display: none;">
        <div class="search-modal-content">
            <span class="close-modal">&times;</span>
            <div class="search-modal-header">
                <i class="fas fa-search"></i>
                <h3>Rechercher</h3>
            </div>
            <div class="search-input-wrapper">
                <input type="text" id="globalSearchInput" placeholder="Rechercher formations, articles..."
                    autocomplete="off">
            </div>
            <div class="search-filters" style="display: flex; gap: 10px; margin: 15px 0; flex-wrap: wrap;">
                <select id="globalSearchType" class="search-filter-select">
                    <option value="all">Tous</option>
                    <option value="formations">Formations</option>
                    <option value="blog">Articles</option>
                </select>
                <select id="globalSearchCategory" class="search-filter-select">
                    <option value="all">Toutes catégories</option>
                    <option value="geomatique">Géomatique</option>
                    <option value="environnement">Environnement</option>
                    <option value="developpement">Développement</option>
                </select>
            </div>
            <div id="globalSearchResults" class="search-results"></div>
        </div>
    </div>

    <!-- Bouton mode sombre -->
    <button id="darkModeToggleBtn" class="dark-mode-toggle"
        style="position: fixed; bottom: 20px; right: 20px; width: 50px; height: 50px; border-radius: 50%; background: var(--primary); color: white; border: none; cursor: pointer; font-size: 24px; z-index: 1000; display: flex; align-items: center; justify-content: center;">
        <i class="fas fa-moon"></i>
    </button>

    <style>
        .search-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(5px);
            z-index: 2000;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .search-modal-content {
            background: white;
            width: 90%;
            max-width: 700px;
            max-height: 85vh;
            border-radius: 15px;
            padding: 30px;
            position: relative;
            overflow-y: auto;
        }

        body.dark-mode .search-modal-content {
            background: #1a1a2e;
            color: #e0e0e0;
        }

        .close-modal {
            position: absolute;
            top: 15px;
            right: 20px;
            font-size: 28px;
            cursor: pointer;
        }

        #globalSearchInput {
            width: 100%;
            padding: 15px 20px;
            border: 2px solid #e0e0e0;
            border-radius: 50px;
            font-size: 16px;
        }

        body.dark-mode #globalSearchInput {
            background: #0f0f1a;
            border-color: #2a2a3e;
            color: #e0e0e0;
        }

        .search-filter-select {
            padding: 8px 15px;
            border: 1px solid #ddd;
            border-radius: 25px;
            background: white;
            cursor: pointer;
        }

        body.dark-mode .search-filter-select {
            background: #0f0f1a;
            border-color: #2a2a3e;
            color: #e0e0e0;
        }

        .search-results {
            margin: 20px 0;
            max-height: 400px;
            overflow-y: auto;
        }

        .search-result-item {
            padding: 15px;
            margin-bottom: 15px;
            background: #f9f9f9;
            border-radius: 10px;
        }

        body.dark-mode .search-result-item {
            background: #0f0f1a;
        }

        /* Animation fadeOut pour le toast */
        @keyframes fadeOut {
            0% {
                opacity: 1;
            }

            70% {
                opacity: 1;
            }

            100% {
                opacity: 0;
                visibility: hidden;
            }
        }
    </style>

    <script>
        // Gestion du mode sombre (version unique)
        (function () {
            const darkModeBtn = document.getElementById('darkModeToggleBtn');
            if (!darkModeBtn) return;

            // Fonction pour mettre à jour l'icône et la classe
            function updateDarkModeUI(isDark) {
                if (isDark) {
                    document.body.classList.add('dark-mode');
                    darkModeBtn.innerHTML = '<i class="fas fa-sun"></i>';
                    darkModeBtn.style.background = '#27ae60';
                } else {
                    document.body.classList.remove('dark-mode');
                    darkModeBtn.innerHTML = '<i class="fas fa-moon"></i>';
                    darkModeBtn.style.background = '#0a5c36';
                }
            }

            // Appliquer le mode sauvegardé ou défaut (sombre)
            let savedMode = localStorage.getItem('darkMode');
            if (isDarkMode === null || isDarkMode === 'true') {
                document.body.classList.add('dark-mode');
                if (darkModeBtn) darkModeBtn.innerHTML = '<i class="fas fa-sun"></i>';
            } else {
                document.body.classList.remove('dark-mode');
                if (darkModeBtn) darkModeBtn.innerHTML = '<i class="fas fa-moon"></i>';
            }
            if (darkModeBtn) {
                darkModeBtn.addEventListener('click', function () {
                    document.body.classList.toggle('dark-mode');
                    const isDark = document.body.classList.contains('dark-mode');
                    localStorage.setItem('darkMode', isDark);
                    darkModeBtn.innerHTML = isDark ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>';
                });
            }

            // Basculer au clic avec notification
            darkModeBtn.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();

                // Vérifier l'état actuel APRÈS la classe
                const isCurrentlyDark = document.body.classList.contains('dark-mode');
                const newMode = !isCurrentlyDark;

                console.log('Clic - Mode actuel (dark):', isCurrentlyDark);
                console.log('Clic - Nouveau mode (dark):', newMode);

                // Mettre à jour le localStorage
                localStorage.setItem('darkMode', newMode ? 'true' : 'false');

                // Appliquer la nouvelle UI
                updateDarkModeUI(newMode);

                // Notification toast
                const toast = document.createElement('div');
                toast.textContent = newMode ? '🌙 Mode sombre activé' : '☀️ Mode clair activé';
                toast.style.cssText = 'position:fixed; bottom:80px; left:50%; transform:translateX(-50%); background:#333; color:white; padding:10px 20px; border-radius:8px; font-size:14px; z-index:9999; animation:fadeOut 2s forwards;';
                document.body.appendChild(toast);
                setTimeout(() => toast.remove(), 2000);
            });
        })();

        // Gestion du menu mobile
        (function () {
            const mobileMenuBtn = document.querySelector('.mobile-menu-btn');
            const closeMenuBtn = document.querySelector('.close-menu');
            const mobileMenuOverlay = document.querySelector('.mobile-menu-overlay');

            if (mobileMenuBtn) {
                mobileMenuBtn.addEventListener('click', () => {
                    mobileMenuOverlay.classList.add('active');
                    document.body.style.overflow = 'hidden';
                });
            }

            if (closeMenuBtn) {
                closeMenuBtn.addEventListener('click', () => {
                    mobileMenuOverlay.classList.remove('active');
                    document.body.style.overflow = 'auto';
                });
            }

            document.querySelectorAll('.mobile-menu-container a').forEach(link => {
                link.addEventListener('click', () => {
                    mobileMenuOverlay.classList.remove('active');
                    document.body.style.overflow = 'auto';
                });
            });
        })();

        // Gestion de la recherche
        (function () {
            const searchToggleBtn = document.getElementById('searchToggleBtn');
            const searchModal = document.getElementById('searchModal');
            const closeModal = document.querySelector('.close-modal');

            if (searchToggleBtn) {
                searchToggleBtn.addEventListener('click', () => {
                    searchModal.style.display = 'flex';
                    const input = document.getElementById('globalSearchInput');
                    if (input) input.focus();
                    document.body.style.overflow = 'hidden';
                });
            }

            function closeSearchModal() {
                searchModal.style.display = 'none';
                document.body.style.overflow = 'auto';
            }

            if (closeModal) closeModal.addEventListener('click', closeSearchModal);
            window.addEventListener('click', (e) => { if (e.target === searchModal) closeSearchModal(); });
            document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && searchModal.style.display === 'flex') closeSearchModal(); });
        })();

    </script>
</body>

</html>