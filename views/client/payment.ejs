<% title = 'Paiement - ' + formation.title %>
<% currentPage = 'client' %>
<% seoTitle = 'Paiement - ' + formation.title + ' - GeoImpact Tech' %>
<% metaDescription = 'Paiement sécurisé pour la formation ' + formation.title %>
<%- include('../partials/header') %>

<script src="https://js.stripe.com/v3/"></script>

<section class="payment-section" style="padding: 120px 0 60px;">
    <div class="container">
        <div class="payment-container" style="max-width: 600px; margin: 0 auto;">
            <div class="payment-card" style="background: white; border-radius: 15px; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.1);">
                <h2 style="text-align: center; margin-bottom: 30px; color: var(--primary);">
                    <i class="fas fa-credit-card"></i> Paiement sécurisé
                </h2>
                
                <div class="formation-summary" style="background: #f9f9f9; padding: 20px; border-radius: 10px; margin-bottom: 30px;">
                    <h3><%= formation.title %></h3>
                    <p><strong>Montant :</strong> <%= Math.round(formation.price * 655).toLocaleString() %> FCFA (<%= formation.price %> €)</p>
                    <p><strong>Durée :</strong> <%= formation.duration %></p>
                    <p><strong>Niveau :</strong> <%= formation.level %></p>
                </div>
                
                <!-- Formulaire de paiement -->
                <div id="stripe-payment" style="margin-bottom: 20px;">
                    <div id="payment-element"></div>
                    <div id="payment-message" style="color: #e74c3c; margin-top: 15px; display: none;"></div>
                </div>
                
                <button id="submit-payment" class="btn" style="width: 100%; padding: 15px; display: block; background: #27ae60; color: white; border: none; border-radius: 8px; font-size: 16px; font-weight: bold; cursor: pointer;">
                    <i class="fas fa-lock"></i> Payer <%= Math.round(formation.price * 655).toLocaleString() %> FCFA
                </button>
                
                <div id="loading" style="text-align: center; padding: 20px; display: none;">
                    <i class="fas fa-spinner fa-spin"></i> Traitement en cours...
                </div>
                
                <p style="text-align: center; margin-top: 15px; font-size: 12px; color: #999;">
                    <i class="fas fa-shield-alt"></i> Paiement sécurisé par Stripe
                </p>
            </div>
        </div>
    </div>
</section>

<script>
    const stripe = Stripe('<%= stripePublicKey %>');
    const formationId = <%= formation.id %>;
    let elements = null;
    
    async function initializePayment() {
        try {
            console.log('🔵 Initialisation du paiement...');
            
            const response = await fetch('/payment/api/create-payment-intent', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ formationId: formationId, paymentMethod: 'card' })
            });
            
            const data = await response.json();
            console.log('📦 Réponse:', data);
            
            if (data.error) {
                document.getElementById('payment-message').textContent = data.error;
                document.getElementById('payment-message').style.display = 'block';
                return;
            }
            
            const elements = stripe.elements({
                clientSecret: data.clientSecret,
                appearance: {
                    theme: 'stripe',
                    variables: {
                        colorPrimary: '#0a5c36',
                        colorBackground: '#ffffff',
                        colorText: '#30313d',
                        colorDanger: '#df1b41',
                        fontFamily: 'Arial, sans-serif',
                        spacingUnit: '4px',
                        borderRadius: '8px',
                    },
                },
            });
            
            const paymentElement = elements.create('payment');
            paymentElement.mount('#payment-element');
            
            // Gérer le bouton de paiement
            document.getElementById('submit-payment').addEventListener('click', async (e) => {
                e.preventDefault();
                
                const submitBtn = document.getElementById('submit-payment');
                const loadingDiv = document.getElementById('loading');
                const messageDiv = document.getElementById('payment-message');
                
                submitBtn.style.display = 'none';
                loadingDiv.style.display = 'block';
                messageDiv.style.display = 'none';
                
                const { error } = await stripe.confirmPayment({
                    elements,
                    confirmParams: {
                        return_url: 'http://localhost:3000/payment/success',
                        receipt_email: '<%= clientEmail %>',
                    },
                    redirect: 'if_required',
                });
                
                if (error) {
                    messageDiv.textContent = error.message;
                    messageDiv.style.display = 'block';
                    submitBtn.style.display = 'block';
                    loadingDiv.style.display = 'none';
                } else {
                    // Paiement réussi
                    const confirmResponse = await fetch('/payment/api/confirm-payment', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            paymentIntentId: data.clientSecret.split('_secret_')[0],
                            formationId: formationId
                        })
                    });
                    
                    const result = await confirmResponse.json();
                    
                    if (result.success) {
                        window.location.href = '/client/my-formations?payment_success=true';
                    } else {
                        messageDiv.textContent = result.error || 'Erreur lors de la confirmation';
                        messageDiv.style.display = 'block';
                        submitBtn.style.display = 'block';
                        loadingDiv.style.display = 'none';
                    }
                }
            });
        } catch (error) {
            console.error('❌ Erreur:', error);
            document.getElementById('payment-message').textContent = 'Erreur de chargement du paiement';
            document.getElementById('payment-message').style.display = 'block';
        }
    }
    
    // Initialiser au chargement
    document.addEventListener('DOMContentLoaded', initializePayment);
</script>

<style>
    body.dark-mode .payment-card {
        background: #1a1a2e;
    }
    body.dark-mode .formation-summary {
        background: #0f0f1a;
    }
</style>

<%- include('../partials/footer') %>