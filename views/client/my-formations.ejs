<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mes formations - Espace Client</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background: #f5f5f5;
        }
        .header {
            background: #0a5c36;
            color: white;
            padding: 15px 20px;
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 100;
        }
        .content {
            padding-top: 80px;
            padding: 80px 20px 20px;
            max-width: 1200px;
            margin: 0 auto;
        }
        .card {
            background: white;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }
        .card img {
            width: 150px;
            height: 150px;
            object-fit: cover;
            border-radius: 10px;
        }
        .card-info {
            flex: 1;
        }
        .btn {
            display: inline-block;
            padding: 8px 20px;
            background: #27ae60;
            color: white;
            text-decoration: none;
            border-radius: 5px;
            margin-top: 10px;
            border: none;
            cursor: pointer;
        }
        .btn:hover {
            background: #0a5c36;
        }
        .logout-btn {
            background: #e74c3c;
            color: white;
            padding: 8px 15px;
            text-decoration: none;
            border-radius: 5px;
            margin-left: 15px;
        }
        .logout-btn:hover {
            background: #c0392b;
        }
        .badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 15px;
            font-size: 12px;
            font-weight: bold;
        }
        .badge-inscrit { background: #3498db; color: white; }
        .badge-en_cours { background: #f39c12; color: white; }
        .badge-termine { background: #27ae60; color: white; }
        .badge-annule { background: #e74c3c; color: white; }
        body.dark-mode .header { background: #0a5c36; }
        body.dark-mode .card { background: #1a1a2e; color: #e0e0e0; }
        body.dark-mode .card-info h3 { color: #27ae60; }
    </style>
</head>
<body>
    <div class="header">
        <div style="display: flex; justify-content: space-between; align-items: center; max-width: 1200px; margin: 0 auto; padding: 0 20px;">
            <h2>Mes formations</h2>
            <div>
                <a href="/client/dashboard" style="color: white; margin-right: 15px;">Dashboard</a>
                <a href="/client/logout" class="logout-btn">Déconnexion</a>
            </div>
        </div>
    </div>

    <div class="content">
        <h1>Mes formations</h1>
        
        <!-- DEBUG -->
        <div style="background: yellow; padding: 10px; margin: 10px 0; border: 2px solid red; color: black;">
            <strong>DEBUG:</strong><br>
            Nombre de formations: <%= formations ? formations.length : 0 %>
        </div>
        
        <% if (formations && formations.length > 0) { %>
            <p><strong><%= formations.length %></strong> formation(s) trouvée(s)</p>
            
            <% for(var i = 0; i < formations.length; i++) { 
                var f = formations[i];
                var statusClass = 'badge-inscrit';
                var statusText = 'Inscrit';
                if (f.statut === 'en_cours') { statusClass = 'badge-en_cours'; statusText = 'En cours'; }
                else if (f.statut === 'termine') { statusClass = 'badge-termine'; statusText = 'Terminé'; }
                else if (f.statut === 'annule') { statusClass = 'badge-annule'; statusText = 'Annulé'; }
            %>
                <div class="card">
                    <img src="<%= f.image_url %>" alt="<%= f.title %>">
                    <div class="card-info">
                        <h3><%= f.title %></h3>
                        <p><strong>Durée:</strong> <%= f.duration %></p>
                        <p><strong>Niveau:</strong> <%= f.level %></p>
                        <p><strong>Catégorie:</strong> <%= f.category %></p>
                        <p><strong>Inscrit le:</strong> <%= new Date(f.date_inscription).toLocaleDateString() %></p>
                        <p>
                            <span class="badge <%= statusClass %>"><%= statusText %></span>
                            <% if (f.quiz_completed) { %>
                                <span class="badge" style="background: #27ae60; color: white;">✅ Quiz: <%= f.quiz_score %>%</span>
                            <% } %>
                            <% if (f.certificate_generated) { %>
                                <span class="badge" style="background: #9b59b6; color: white;">🎓 Certificat</span>
                            <% } %>
                        </p>
                        <a href="/client/formation/<%= f.formation_id %>/learn" class="btn">
                            <i class="fas fa-play-circle"></i> Accéder à la formation
                        </a>
                    </div>
                </div>
            <% } %>
        <% } else { %>
            <p>Aucune formation trouvée.</p>
            <a href="/formations" class="btn">Voir les formations disponibles</a>
        <% } %>
    </div>

    <script>
        (function() {
            const savedDarkMode = localStorage.getItem('darkMode');
            if (savedDarkMode === null || savedDarkMode === 'true') {
                document.body.classList.add('dark-mode');
            }
        })();
    </script>
</body>
</html>