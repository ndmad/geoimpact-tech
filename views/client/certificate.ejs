<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mon certificat - <%= certificate.formation_title %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Georgia', serif;
            background: #1a1a2e;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px;
        }
        .certificate {
            max-width: 900px;
            background: white;
            padding: 50px;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            text-align: center;
            border: 15px solid #f5f5f5;
            position: relative;
        }
        .certificate::before {
            content: '';
            position: absolute;
            top: 10px;
            left: 10px;
            right: 10px;
            bottom: 10px;
            border: 2px solid #27ae60;
            border-radius: 10px;
            pointer-events: none;
        }
        .certificate-header {
            margin-bottom: 40px;
        }
        .certificate-header h1 {
            font-size: 42px;
            color: #0a5c36;
            letter-spacing: 2px;
        }
        .certificate-header p {
            color: #666;
            font-size: 14px;
        }
        .certificate-body {
            margin: 40px 0;
        }
        .certificate-body p {
            font-size: 20px;
            color: #333;
            margin: 15px 0;
        }
        .student-name {
            font-size: 36px;
            font-weight: bold;
            color: #27ae60;
            margin: 30px 0;
            font-family: 'Arial', sans-serif;
        }
        .course-name {
            font-size: 24px;
            font-weight: bold;
            color: #0a5c36;
            margin: 20px 0;
        }
        .certificate-footer {
            margin-top: 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 30px;
            border-top: 1px solid #eee;
        }
        .certificate-number {
            font-size: 12px;
            color: #999;
            text-align: left;
        }
        .certificate-date {
            font-size: 12px;
            color: #999;
            text-align: right;
        }
        .btn-group {
            margin-top: 30px;
            display: flex;
            gap: 15px;
            justify-content: center;
        }
        .btn {
            padding: 12px 25px;
            background: #27ae60;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            transition: all 0.3s;
        }
        .btn:hover {
            background: #0a5c36;
            transform: translateY(-2px);
        }
        .btn-secondary {
            background: #666;
        }
        .btn-secondary:hover {
            background: #555;
        }
    </style>
</head>
<body>
    <div class="certificate">
        <div class="certificate-header">
            <h1>CERTIFICAT DE RÉUSSITE</h1>
            <p>Ce certificat est décerné à</p>
        </div>
        
        <div class="certificate-body">
            <div class="student-name">
                <%= certificate.prenom %> <%= certificate.nom %>
            </div>
            <p>Pour avoir complété avec succès la formation</p>
            <div class="course-name">
                <%= certificate.formation_title %>
            </div>
            <p>Avec une mention spéciale pour son investissement et sa détermination.</p>
        </div>
        
        <div class="certificate-footer">
            <div class="certificate-number">
                <i class="fas fa-hashtag"></i> Réf: <%= certificate.certificate_number %>
            </div>
            <div class="certificate-date">
                <i class="far fa-calendar-alt"></i> Délivré le <%= new Date(certificate.issue_date).toLocaleDateString() %>
            </div>
        </div>
        
        <div class="btn-group">
            <a href="/client/api/certificate/download/<%= certificate.id %>" class="btn">
                <i class="fas fa-download"></i> Télécharger PDF
            </a>
            <a href="/client/my-formations" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Mes formations
            </a>
        </div>
    </div>
</body>
</html>