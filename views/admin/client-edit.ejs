<%- include('../partials/admin-header') %>

<div class="page-header">
    <h2>Modifier le client</h2>
    <a href="/admin/clients/view/<%= client.id %>" class="btn">← Retour</a>
</div>

<% if (typeof success_msg !== 'undefined' && success_msg) { %>
    <div class="alert alert-success"><%= success_msg %></div>
<% } %>
<% if (typeof error_msg !== 'undefined' && error_msg) { %>
    <div class="alert alert-error"><%= error_msg %></div>
<% } %>

<div style="background: white; padding: 25px; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
    <form action="/admin/clients/edit/<%= client.id %>" method="POST">
        <div class="form-group">
            <label>Prénom *</label>
            <input type="text" name="prenom" value="<%= client.prenom %>" required>
        </div>
        <div class="form-group">
            <label>Nom *</label>
            <input type="text" name="nom" value="<%= client.nom %>" required>
        </div>
        <div class="form-group">
            <label>Email</label>
            <input type="email" value="<%= client.email %>" disabled style="background: #f0f0f0;">
            <small style="color: #999;">L'email ne peut pas être modifié</small>
        </div>
        <div class="form-group">
            <label>Téléphone</label>
            <input type="tel" name="telephone" value="<%= client.telephone || '' %>">
        </div>
        <div class="form-group">
            <label>Entreprise</label>
            <input type="text" name="entreprise" value="<%= client.entreprise || '' %>">
        </div>
        <div class="form-group">
            <label>Fonction</label>
            <input type="text" name="fonction" value="<%= client.fonction || '' %>">
        </div>
        
        <div style="display: flex; gap: 10px; margin-top: 20px;">
            <button type="submit" class="btn">💾 Enregistrer</button>
            <a href="/admin/clients/view/<%= client.id %>" class="btn" style="background: #666;">Annuler</a>
        </div>
    </form>
</div>

<%- include('../partials/admin-footer') %>