<%- include('../partials/admin-header') %>

<div class="page-header">
    <h2>Gestion des formations</h2>
    <a href="/admin/formations/new" class="btn">+ Ajouter une formation</a>
</div>

<% if (typeof success_msg !== 'undefined' && success_msg) { %>
    <div class="alert alert-success"><%= success_msg %></div>
<% } %>
<% if (typeof error_msg !== 'undefined' && error_msg) { %>
    <div class="alert alert-error"><%= error_msg %></div>
<% } %>

<table>
    <thead>
        <tr>
            <th>ID</th>
            <th>Titre</th>
            <th>Durée</th>
            <th>Niveau</th>
            <th>Catégorie</th>
            <th>Prix</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <% if (formations && formations.length > 0) { %>
            <% formations.forEach(function(f) { %>
            <tr>
                <td><%= f.id %></td>
                <td><%= f.title %></td>
                <td><%= f.duration %></td>
                <td><%= f.level %></td>
                <td><%= f.category %></td>
                <td><%= f.price ? f.price + ' €' : 'Gratuit' %></td>
                <td style="white-space: nowrap;">
                    <a href="/admin/formations/edit/<%= f.id %>" class="btn-edit">Modifier</a>
                    <a href="/admin/formations/delete/<%= f.id %>" class="btn-delete" onclick="return confirm('Supprimer cette formation ?')">Supprimer</a>
                </td>
            </tr>
            <% }); %>
        <% } else { %>
            <tr><td colspan="7" style="text-align:center;">Aucune formation</td></tr>
        <% } %>
    </tbody>
</table>

<%- include('../partials/admin-footer') %>